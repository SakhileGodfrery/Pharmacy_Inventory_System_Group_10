# --- 1. DATABASE CONNECTION ---
def get_connection():
    try:
        return psycopg2.connect(
            user="postgres",
            password="Enter_Password", # <--- CHANGE TO YOUR POSTGRESQL PASSWORD
            host="127.0.0.1",
            port="5432",
            database="pharmacy_inventory"
        )
    except (Exception, Error) as error:
        return None

